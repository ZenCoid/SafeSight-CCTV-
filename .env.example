# ═══════════════════════════════════════════════════════════════════
# SafeSight CCTV Configuration
# Copy this file to .env and fill in your values
# ═══════════════════════════════════════════════════════════════════

# ── Model ───────────────────────────────────────────────────────
MODEL_PATH=weights/best.pt
CONFIDENCE_THRESHOLD=0.45
DETECTION_INTERVAL=1

# ── YOLO Inference ─────────────────────────────────────────────
YOLO_IMGSZ=1280
YOLO_AUGMENT=true
YOLO_IOU=0.3
YOLO_MAX_DET=50

# ── Class-Specific Detection Thresholds ────────────────────────
# These control sensitivity per object type (NEW: was hardcoded before)
# Helmet: 0.35 blocks caps, allows real hard hats
# No Helmet: 0.20 is lenient for safety priority
# Worker: 0.25 is moderate for person detection
THRESHOLD_HELMET=0.35
THRESHOLD_NO_HELMET=0.20
THRESHOLD_WORKER=0.25

# ── CLAHE Preprocessing (LAB color space) ─────────────────────
# Enhances contrast in shadows/overexposure for better detection
CLAHE_ENABLED=true
CLAHE_CLIP_LIMIT=2.0
CLAHE_TILE_SIZE=8

# ── Frame Upscaling ────────────────────────────────────────────
# Upscales small CCTV sub-streams (e.g., 352x288) to MIN_FRAME_DIMENSION
# for better helmet detection accuracy
FRAME_UPSCALE=true
MIN_FRAME_DIMENSION=720

# ── Temporal Smoothing ─────────────────────────────────────────
# Detections must persist across multiple frames to be confirmed
# Reduces flickering from momentary false positives
SMOOTHING_BUFFER_SIZE=5
SMOOTHING_MIN_HITS=2
SMOOTHING_IOU_THRESHOLD=0.15

# ── Streaming ──────────────────────────────────────────────────
STREAM_FPS=25
JPEG_QUALITY=80
JPEG_QUALITY_HD=90

# ── Server ─────────────────────────────────────────────────────
SERVER_HOST=0.0.0.0
SERVER_PORT=8000
LOG_LEVEL=INFO

# ── RTSP ───────────────────────────────────────────────────────
# 0 = main stream (HD), 1 = sub-stream (lower quality, faster)
RTSP_SUBTYPE=0

# ── Gmail SMTP Alerts ──────────────────────────────────────────
SMTP_ENABLED=false
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_EMAIL=your_email@gmail.com
SMTP_PASSWORD=your_app_password_here
SMTP_TO=your_email@gmail.com

# ── Database ───────────────────────────────────────────────────
DB_PATH=violations.db

# ── Snapshots ──────────────────────────────────────────────────
SNAPSHOT_DIR=violations
SNAPSHOT_QUALITY=90

# ── Violation Tracking ─────────────────────────────────────────
# VIOLATION_THRESHOLD: Consecutive detection frames to trigger alert
# VIOLATION_COOLDOWN: Seconds between alerts for same camera
VIOLATION_THRESHOLD=5
VIOLATION_COOLDOWN=30